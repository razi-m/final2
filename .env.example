# Copy this file to .env and fill in your values. Never commit .env.

# Database — SQLite for local dev, swap to PostgreSQL for production
DATABASE_URL=sqlite:///./hacksav.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ariados

# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string

# ML service location
ML_SERVICE_URL=http://localhost:8001

# Path to the ML model weights file
MODEL_PATH=models/best_model.pt

# Admin account bootstrap — set these to create the first admin on startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password

# CORS — comma-separated list of allowed frontend origins
# In production set this to your actual domain, e.g. https://ariados.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173
